#!/bin/zsh
# OpenCode wrapper - auto-detects new accounts on /connect
# Part of ai-switch: https://github.com/yizhen0322/ai-switch
#
# This wrapper intercepts opencode calls to detect when users
# authenticate with new accounts via /connect command.

REAL_OPENCODE="$HOME/.opencode/bin/opencode"
AI_SWITCH="$HOME/.local/bin/ai-switch"
DEFAULT_AUTH="$HOME/.local/share/opencode/auth.json"
AUTH_HELPER="${0:A:h}/ai-switch-auth"

if [[ -f "$AUTH_HELPER" ]]; then
  source "$AUTH_HELPER"
fi

# Extract account ID from auth.json for change detection
get_account_id_from_file() {
  auth_account_id_from_file "$1"
}

# Record current account ID before launch
old_account_id=""
if [[ -f "$DEFAULT_AUTH" ]]; then
  old_account_id=$(get_account_id_from_file "$DEFAULT_AUTH")
fi

# Run the real opencode
"$REAL_OPENCODE" "$@"
exit_code=$?

# After exit, check if a new account was added via /connect
if [[ -f "$DEFAULT_AUTH" ]]; then
  new_account_id=$(get_account_id_from_file "$DEFAULT_AUTH")
  
  if [[ -n "$new_account_id" && "$new_account_id" != "$old_account_id" ]]; then
    # Delegate to ai-switch for auto-add logic
    "$AI_SWITCH" __auto_add_default "$old_account_id" 2>/dev/null || true
  fi
fi

exit $exit_code
