#!/bin/zsh
# AI Multi-Account Manager for OpenCode
# Usage: ai [command] [account]
#
# Config file: ~/.config/ai-accounts.conf

DATA_HOME_ROOT="$HOME/.local/share"
CONFIG_HOME_ROOT="$HOME/.config"
STATE_HOME_ROOT="$HOME/.local/state"
USAGE_FILE="$HOME/.local/share/ai-usage.json"
ACCOUNTS_CONF="$HOME/.config/ai-accounts.conf"
BASE_CONFIG="$HOME/.config/opencode"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

# Parse accounts from config file
declare -A ACCOUNT_TYPES
declare -A ACCOUNT_SHORTCUTS
declare -A ACCOUNT_NAMES  # display name (from email)
declare -A SHORTCUT_TO_ACCOUNT
ACCOUNTS=()

load_accounts() {
  if [[ ! -f "$ACCOUNTS_CONF" ]]; then
    echo -e "${RED}Config not found: $ACCOUNTS_CONF${NC}"
    return 1
  fi
  
  while IFS=: read -r name type shortcut display_name; do
    # Skip comments and empty lines
    [[ "$name" =~ ^#.*$ || -z "$name" ]] && continue
    
    ACCOUNTS+=("$name")
    ACCOUNT_TYPES[$name]="$type"
    ACCOUNT_SHORTCUTS[$name]="$shortcut"
    ACCOUNT_NAMES[$name]="${display_name:-}"
    SHORTCUT_TO_ACCOUNT[$shortcut]="$name"
  done < "$ACCOUNTS_CONF"
}

get_account_config_home() {
  echo "$CONFIG_HOME_ROOT/opencode-$1"
}

get_account_data_home() {
  echo "$DATA_HOME_ROOT/opencode-$1"
}

get_account_state_home() {
  echo "$STATE_HOME_ROOT/opencode-$1"
}

get_account_config_dir() {
  echo "$(get_account_config_home "$1")/opencode"
}

get_account_data_dir() {
  echo "$(get_account_data_home "$1")/opencode"
}

get_account_auth_file() {
  echo "$(get_account_data_dir "$1")/auth.json"
}

get_account_codex_home() {
  echo "$DATA_HOME_ROOT/codex-$1"
}

get_account_codex_auth_file() {
  echo "$(get_account_codex_home "$1")/auth.json"
}

# Initialize usage file if not exists
init_usage() {
  if [[ ! -f "$USAGE_FILE" ]]; then
    echo '{}' > "$USAGE_FILE"
  fi
}

record_account_usage_timestamp() {
  local acc="$1"
  local now=$(date +%s)
  local tmp=$(mktemp)

  jq --arg acc "$acc" --argjson now "$now" '
    .[$acc] = (
      if (.[$acc] | type) == "object" then
        .[$acc] + {lastUsedAt: $now}
      else
        {lastUsedAt: $now}
      end
    )
  ' "$USAGE_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$USAGE_FILE"
}

cache_rate_limits() {
  local acc="$1"
  local response="$2"
  local now=$(date +%s)
  local tmp=$(mktemp)

  jq --arg acc "$acc" --argjson now "$now" --argjson rate "$response" '
    .[$acc] = (
      if (.[$acc] | type) == "object" then
        .[$acc] + {lastRateLimits: $rate, lastRateLimitsAt: $now}
      else
        {lastRateLimits: $rate, lastRateLimitsAt: $now}
      end
    )
  ' "$USAGE_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$USAGE_FILE"
}

format_reset_time() {
  local resets_at="$1"

  if [[ -n "$resets_at" && "$resets_at" != "null" && "$resets_at" -gt 0 ]]; then
    date -r "$resets_at" "+%H:%M on %d %b" 2>/dev/null || echo "unknown"
  else
    echo "unknown"
  fi
}

get_window_label() {
  local window_mins="$1"

  case "$window_mins" in
    300) echo "5h limit" ;;
    10080) echo "Weekly limit" ;;
    1440) echo "Daily limit" ;;
    *) echo "${window_mins}m limit" ;;
  esac
}

format_limit_compact() {
  local used="$1"
  local resets_at="$2"
  local reset_formatted=$(format_reset_time "$resets_at")
  local remaining=$((100 - used))
  if [[ "$remaining" -lt 0 ]]; then
    remaining=0
  fi

  printf '%s' "${remaining}% left (${reset_formatted})"
}

display_limit_window() {
  local label="$1"
  local used="$2"
  local resets_at="$3"
  local reset_formatted=$(format_reset_time "$resets_at")
  local remaining=$((100 - used))
  if [[ "$remaining" -lt 0 ]]; then
    remaining=0
  fi
  local bar_length=20
  local filled=$((bar_length * used / 100))
  local empty=$((bar_length - filled))
  local bar=""

  for ((i=0; i<filled; i++)); do bar+="█"; done
  for ((i=0; i<empty; i++)); do bar+="░"; done

  local prefix=""
  if [[ -n "$label" ]]; then
    prefix="${label}: "
  fi

  if [[ "$used" -ge 100 ]]; then
    echo -e "  ${prefix}${RED}${bar}${NC} ${RED}${remaining}% left${NC} (${reset_formatted})"
  elif [[ "$used" -ge 80 ]]; then
    echo -e "  ${prefix}${YELLOW}${bar}${NC} ${YELLOW}${remaining}% left${NC} (${reset_formatted})"
  else
    echo -e "  ${prefix}${GREEN}${bar}${NC} ${remaining}% left (${reset_formatted})"
  fi
}

get_cached_limit_summary() {
  local acc="$1"
  local response=$(jq -c --arg acc "$acc" '
    .[$acc]
    | if type == "object" then .lastRateLimits // empty else empty end
  ' "$USAGE_FILE" 2>/dev/null)

  if [[ -z "$response" || "$response" == "null" ]]; then
    return
  fi

  local primary_used=$(printf '%s\n' "$response" | jq -r '.rateLimits.primary.usedPercent // empty' 2>/dev/null)
  local primary_window=$(printf '%s\n' "$response" | jq -r '.rateLimits.primary.windowDurationMins // empty' 2>/dev/null)
  local primary_resets=$(printf '%s\n' "$response" | jq -r '.rateLimits.primary.resetsAt // 0' 2>/dev/null)
  local secondary_used=$(printf '%s\n' "$response" | jq -r '.rateLimits.secondary.usedPercent // empty' 2>/dev/null)
  local secondary_window=$(printf '%s\n' "$response" | jq -r '.rateLimits.secondary.windowDurationMins // empty' 2>/dev/null)
  local secondary_resets=$(printf '%s\n' "$response" | jq -r '.rateLimits.secondary.resetsAt // 0' 2>/dev/null)

  if [[ -n "$secondary_used" ]]; then
    printf '%s | %s' \
      "$(get_window_label "$primary_window") $(format_limit_compact "$primary_used" "$primary_resets")" \
      "$(get_window_label "$secondary_window") $(format_limit_compact "$secondary_used" "$secondary_resets")"
  elif [[ -n "$primary_used" ]]; then
    printf '%s' "$(format_limit_compact "$primary_used" "$primary_resets")"
  fi
}

# Get usage from Codex app-server (programmatic access to rate limits)
get_codex_command() {
  if command -v codex >/dev/null 2>&1; then
    echo "codex"
  fi
}

has_codex_cli() {
  [[ -n "$(get_codex_command)" ]]
}

has_curl_cli() {
  command -v curl >/dev/null 2>&1
}

get_codex_usage() {
  local codex_home="$1"
  local auth_file="$codex_home/auth.json"
  local codex_cmd=$(get_codex_command)
  local init_request=$(jq -cn '{jsonrpc:"2.0",id:1,method:"initialize",params:{clientInfo:{name:"ai-switch",version:"1.0.0"},capabilities:{experimentalApi:true}}}')
  local login_request=""
  local rate_request_id=2

  [[ -z "$codex_cmd" ]] && return

  if [[ -f "$auth_file" ]] && jq -e '.openai? != null' "$auth_file" >/dev/null 2>&1; then
    local access_token=$(jq -r '.openai.access // empty' "$auth_file" 2>/dev/null)
    local account_id=$(jq -r '.openai.accountId // empty' "$auth_file" 2>/dev/null)

    if [[ -n "$access_token" && -n "$account_id" ]]; then
      login_request=$(jq -cn \
        --arg accessToken "$access_token" \
        --arg chatgptAccountId "$account_id" \
        '{jsonrpc:"2.0",id:2,method:"account/login/start",params:{type:"chatgptAuthTokens",accessToken:$accessToken,chatgptAccountId:$chatgptAccountId,chatgptPlanType:null}}')
      rate_request_id=3
    fi
  fi

  local rate_request=$(jq -cn --argjson id "$rate_request_id" '{jsonrpc:"2.0",id:$id,method:"account/rateLimits/read",params:null}')

  local response=$({
    printf '%s\n' "$init_request"
    sleep 1

    if [[ -n "$login_request" ]]; then
      printf '%s\n' "$login_request"
      sleep 1
    fi

    printf '%s\n' "$rate_request"
    sleep 4
  } | CODEX_HOME="$codex_home" "$codex_cmd" app-server 2>/dev/null)

  local result=$(printf '%s\n' "$response" | jq -cr "select(.id == $rate_request_id) | .result // empty" 2>/dev/null)

  if [[ -n "$result" && "$result" != "null" ]]; then
    printf '%s\n' "$result"
  fi
}

LAST_USAGE_SOURCE=""
RATE_LIMITS_RESPONSE=""

status_line_used_percent() {
  local line="$1"

  if [[ "$line" =~ '([0-9]+)%[[:space:]]*left' ]]; then
    local remaining=${match[1]}
    local used=$((100 - remaining))
    (( used < 0 )) && used=0
    (( used > 100 )) && used=100
    echo "$used"
    return 0
  fi

  if [[ "$line" =~ '([0-9]+)%[[:space:]]*used' ]]; then
    local used=${match[1]}
    (( used < 0 )) && used=0
    (( used > 100 )) && used=100
    echo "$used"
    return 0
  fi

  return 1
}

get_codex_status_output() {
  local codex_home="$1"
  local codex_cmd=$(get_codex_command)

  [[ -z "$codex_cmd" ]] && return
  command -v expect >/dev/null 2>&1 || return

  EXPECT_CODEX_CMD="$codex_cmd" EXPECT_CODEX_HOME="$codex_home" expect -c '
    log_user 0
    set timeout 15
    set cmd $env(EXPECT_CODEX_CMD)
    set codex_home $env(EXPECT_CODEX_HOME)
    spawn env TERM=dumb NO_COLOR=1 CODEX_HOME=$codex_home $cmd
    after 1000
    send "/status\r"
    after 1000
    send "/exit\r"
    expect eof
    puts $expect_out(buffer)
  ' 2>/dev/null
}

get_codex_status_rate_limits() {
  local codex_home="$1"
  local fallback_plan="$2"
  local status_output=$(get_codex_status_output "$codex_home")

  [[ -z "$status_output" ]] && return

  local primary_used=""
  local secondary_used=""
  local credits_balance=0
  local line

  while IFS= read -r line; do
    [[ -z "$primary_used" && "$line" == *"5h limit"* ]] && primary_used=$(status_line_used_percent "$line" 2>/dev/null || true)
    [[ -z "$secondary_used" && "$line" == *"Weekly limit"* ]] && secondary_used=$(status_line_used_percent "$line" 2>/dev/null || true)

    if [[ "$line" =~ 'Credits:[[:space:]]*([0-9]+)' ]]; then
      credits_balance=${match[1]}
    fi
  done <<< "$status_output"

  if [[ -z "$primary_used" && -z "$secondary_used" ]]; then
    return
  fi

  [[ -z "$primary_used" ]] && primary_used=0

  jq -cn \
    --argjson primaryUsed "$primary_used" \
    --argjson secondaryUsed "${secondary_used:-0}" \
    --arg hasSecondary "${secondary_used:+true}" \
    --argjson credits "$credits_balance" \
    --arg plan "$fallback_plan" '
      {
        rateLimits: (
          {
            primary: {
              usedPercent: $primaryUsed,
              windowDurationMins: 300,
              resetsAt: 0
            },
            planType: $plan,
            credits: {
              hasCredits: ($credits > 0),
              balance: $credits
            }
          }
          + (if $hasSecondary == "true" then {
              secondary: {
                usedPercent: $secondaryUsed,
                windowDurationMins: 10080,
                resetsAt: 0
              }
            } else {} end)
        )
      }
    '
}

load_rate_limits_response() {
  local app_server_home="$1"
  local fallback_codex_home="${2:-}"
  local fallback_plan="${3:-unknown}"

  RATE_LIMITS_RESPONSE=""
  LAST_USAGE_SOURCE=""

  local response=$(get_codex_usage "$app_server_home")
  if [[ -n "$response" ]]; then
    RATE_LIMITS_RESPONSE="$response"
    LAST_USAGE_SOURCE="Codex app-server"
    return 0
  fi

  if [[ -n "$fallback_codex_home" ]]; then
    response=$(get_codex_status_rate_limits "$fallback_codex_home" "$fallback_plan")
    if [[ -n "$response" ]]; then
      RATE_LIMITS_RESPONSE="$response"
      LAST_USAGE_SOURCE="codex /status fallback"
      return 0
    fi
  fi

  return 1
}

refresh_rate_limits_cache() {
  local acc="$1"
  local app_server_home="$2"
  local fallback_codex_home="${3:-}"
  local fallback_plan="${4:-unknown}"

  if load_rate_limits_response "$app_server_home" "$fallback_codex_home" "$fallback_plan"; then
    cache_rate_limits "$acc" "$RATE_LIMITS_RESPONSE"
    return 0
  fi

  return 1
}

# Parse and display rate limits from app-server response
display_rate_limits() {
  local app_server_home=$1
  local acc=${2:-}
  local fallback_codex_home="${3:-}"
  local fallback_plan="${4:-unknown}"

  if ! load_rate_limits_response "$app_server_home" "$fallback_codex_home" "$fallback_plan"; then
    return 1
  fi

  local response="$RATE_LIMITS_RESPONSE"

  if [[ -n "$acc" ]]; then
    cache_rate_limits "$acc" "$response"
  fi
  
  # Extract key values
  local primary_used=$(echo "$response" | jq -r '.rateLimits.primary.usedPercent // 0' 2>/dev/null)
  local primary_resets=$(echo "$response" | jq -r '.rateLimits.primary.resetsAt // 0' 2>/dev/null)
  local primary_window=$(echo "$response" | jq -r '.rateLimits.primary.windowDurationMins // 0' 2>/dev/null)
  local secondary_used=$(echo "$response" | jq -r '.rateLimits.secondary.usedPercent // empty' 2>/dev/null)
  local secondary_window=$(echo "$response" | jq -r '.rateLimits.secondary.windowDurationMins // empty' 2>/dev/null)
  local secondary_resets=$(echo "$response" | jq -r '.rateLimits.secondary.resetsAt // 0' 2>/dev/null)
  local plan_type=$(echo "$response" | jq -r '.rateLimits.planType // "unknown"' 2>/dev/null)
  local has_credits=$(echo "$response" | jq -r '.rateLimits.credits.hasCredits // false' 2>/dev/null)
  local credits_balance=$(echo "$response" | jq -r '.rateLimits.credits.balance // 0' 2>/dev/null)
  
  # Display
  echo ""
  echo -e "${BOLD}Usage Limits:${NC}"

  if [[ -n "$secondary_used" ]]; then
    display_limit_window "$(get_window_label "$primary_window")" "$primary_used" "$primary_resets"
    display_limit_window "$(get_window_label "$secondary_window")" "$secondary_used" "$secondary_resets"
  else
    display_limit_window "" "$primary_used" "$primary_resets"
  fi
  
  if [[ "$has_credits" == "true" && "$credits_balance" -gt 0 ]]; then
    echo -e "  Credits: ${BOLD}${credits_balance}${NC}"
  fi
  
  echo -e "  Plan: ${BOLD}${plan_type}${NC}"
  
  return 0
}

get_copilot_usage() {
  local auth_file="$1"

  [[ ! -f "$auth_file" ]] && return
  has_curl_cli || return

  local access_token=$(jq -r '.["github-copilot"].access // empty' "$auth_file" 2>/dev/null)
  [[ -z "$access_token" || "$access_token" == "null" ]] && return

  curl -fsSL \
    -H "Accept: application/json" \
    -H "Authorization: token $access_token" \
    -H "Editor-Version: vscode/1.96.2" \
    -H "Editor-Plugin-Version: copilot-chat/0.26.7" \
    -H "User-Agent: GitHubCopilotChat/0.26.7" \
    -H "X-Github-Api-Version: 2025-04-01" \
    "https://api.github.com/copilot_internal/user" 2>/dev/null
}

get_copilot_login() {
  local auth_file="$1"
  local response=$(get_copilot_usage "$auth_file")

  [[ -z "$response" ]] && return

  printf '%s\n' "$response" | jq -r '.login // empty' 2>/dev/null
}

get_copilot_percent_remaining() {
  local response="$1"
  local key="$2"

  printf '%s\n' "$response" | jq -r --arg key "$key" '
    (
      .quotaSnapshots // .quota_snapshots // .data.quotaSnapshots // .data.quota_snapshots // {}
    )[$key] // empty
    | (
        .percentRemaining //
        .percent_remaining //
        .remainingPercent //
        .remaining_percent //
        (if ((.remaining // .remaining_count // empty) != empty) and ((.quota // .total // .limit // empty) != empty)
          then (((.remaining // .remaining_count) * 100) / (.quota // .total // .limit) | floor)
          else empty
        end)
      ) // empty
  ' 2>/dev/null
}

# Get copilot premium percentage for status line (returns "XX% left" format)
get_copilot_limit_summary() {
  local acc="$1"
  local home_dir=$(get_account_data_home "$acc")
  local auth_file="$home_dir/opencode/auth.json"
  
  [[ ! -f "$auth_file" ]] && return
  
  local response=$(get_copilot_usage "$auth_file")
  [[ -z "$response" ]] && return
  
  local premium_remaining=$(get_copilot_percent_remaining "$response" "premium_interactions")
  [[ -z "$premium_remaining" ]] && premium_remaining=$(get_copilot_percent_remaining "$response" "premiumInteractions")
  
  [[ -z "$premium_remaining" ]] && return
  
  local premium_int=$(printf '%.0f' "$premium_remaining")
  echo "${premium_int}% left"
}

display_copilot_usage() {
  local auth_file="$1"
  local response=$(get_copilot_usage "$auth_file")

  [[ -z "$response" ]] && return 1

  # Try snake_case first (real GitHub API format), then camelCase for compatibility
  local premium_remaining=$(get_copilot_percent_remaining "$response" "premium_interactions")
  [[ -z "$premium_remaining" ]] && premium_remaining=$(get_copilot_percent_remaining "$response" "premiumInteractions")
  local chat_remaining=$(get_copilot_percent_remaining "$response" "chat")

  if [[ -z "$premium_remaining" && -z "$chat_remaining" ]]; then
    return 1
  fi

  LAST_USAGE_SOURCE="GitHub Copilot private usage API"

  echo ""
  echo -e "${BOLD}Usage Limits:${NC}"

  if [[ -n "$premium_remaining" ]]; then
    # Convert float to int for bash arithmetic
    local premium_int=$(printf '%.0f' "$premium_remaining")
    display_limit_window "Premium interactions" "$((100 - premium_int))" 0
  fi

  if [[ -n "$chat_remaining" ]]; then
    local chat_int=$(printf '%.0f' "$chat_remaining")
    display_limit_window "Chat messages" "$((100 - chat_int))" 0
  fi

  echo -e "  Plan: ${BOLD}copilot${NC}"
  return 0
}

get_opencode_account_email() {
  local codex_home="$1"
  local auth_file="$codex_home/auth.json"
  local codex_cmd=$(get_codex_command)

  if [[ ! -f "$auth_file" ]] || ! jq -e '.openai? != null' "$auth_file" >/dev/null 2>&1 || [[ -z "$codex_cmd" ]]; then
    return
  fi

  local access_token=$(jq -r '.openai.access // empty' "$auth_file" 2>/dev/null)
  local account_id=$(jq -r '.openai.accountId // empty' "$auth_file" 2>/dev/null)

  if [[ -z "$access_token" || -z "$account_id" ]]; then
    return
  fi

  local init_request=$(jq -cn '{jsonrpc:"2.0",id:1,method:"initialize",params:{clientInfo:{name:"ai-switch",version:"1.0.0"},capabilities:{experimentalApi:true}}}')
  local login_request=$(jq -cn \
    --arg accessToken "$access_token" \
    --arg chatgptAccountId "$account_id" \
    '{jsonrpc:"2.0",id:2,method:"account/login/start",params:{type:"chatgptAuthTokens",accessToken:$accessToken,chatgptAccountId:$chatgptAccountId,chatgptPlanType:null}}')
  local account_request=$(jq -cn '{jsonrpc:"2.0",id:3,method:"account/read",params:{refreshToken:false}}')

  local response=$({
    printf '%s\n' "$init_request"
    sleep 1
    printf '%s\n' "$login_request"
    sleep 1
    printf '%s\n' "$account_request"
    sleep 2
  } | CODEX_HOME="$codex_home" "$codex_cmd" app-server 2>/dev/null)

  local email=$(printf '%s\n' "$response" | jq -r 'select(.id == 3) | .result.account.email // empty' 2>/dev/null)
  if [[ -n "$email" && "$email" != "null" ]]; then
    printf '%s\n' "$email"
  fi
}

# Get display name (full email or custom name)
get_display_name() {
  local acc=$1
  
  # First check if we have a stored display name
  if [[ -n "${ACCOUNT_NAMES[$acc]}" ]]; then
    echo "${ACCOUNT_NAMES[$acc]}"
    return
  fi
  
  # Otherwise try to get from email
  local email=$(get_email "$acc")
  if [[ -n "$email" ]]; then
    echo "$email"
  else
    echo ""
  fi
}

get_resolved_display_name() {
  local acc="$1"
  local type="${ACCOUNT_TYPES[$acc]}"

  case "$type" in
    free|plus|api)
      get_email "$acc"
      ;;
    copilot)
      get_copilot_login "$(get_account_auth_file "$acc")"
      ;;
  esac
}

sync_display_name() {
  local acc="$1"
  local current_display="${ACCOUNT_NAMES[$acc]}"
  local resolved_display="$(get_resolved_display_name "$acc")"

  [[ -z "$resolved_display" ]] && return 1

  if [[ -z "$current_display" || "$current_display" == "${resolved_display%%@*}" ]]; then
    if [[ "$current_display" != "$resolved_display" ]]; then
      update_display_name "$acc" "$resolved_display"
    fi
  fi

  printf '%s\n' "${ACCOUNT_NAMES[$acc]:-$resolved_display}"
}

# Get email from account's auth.json
get_email() {
  local acc=$1
  local auth_file="$(get_account_auth_file "$acc")"
  local codex_home="$(get_account_data_dir "$acc")"
  
  local id_token=$(jq -r '.tokens.id_token // empty' "$auth_file" 2>/dev/null)
  if [[ -n "$id_token" && "$id_token" != "null" ]]; then
    # Decode JWT to get email
    local jwt_payload=$(echo "$id_token" | cut -d'.' -f2 | base64 -d 2>/dev/null)
    local acc_email=$(echo "$jwt_payload" | jq -r '.email // empty' 2>/dev/null)
    if [[ -n "$acc_email" && "$acc_email" != "null" ]]; then
      echo "$acc_email"
      return
    fi
  fi

  get_opencode_account_email "$codex_home"
}

# Check if account is logged in
is_logged_in() {
  local acc=$1
  local auth_file="$(get_account_auth_file "$acc")"
  [[ -f "$auth_file" ]] && [[ -s "$auth_file" ]]
}

get_account_id_for_provider() {
  local auth_file="$1"
  local provider="$2"

  [[ ! -f "$auth_file" ]] && return

  case "$provider" in
    openai)
      local openai_id=$(jq -r '.openai.accountId // .tokens.accountId // empty' "$auth_file" 2>/dev/null)
      if [[ -n "$openai_id" && "$openai_id" != "null" ]]; then
        echo "openai:$openai_id"
      fi
      ;;
    copilot)
      local copilot_token=$(jq -r '.["github-copilot"].access // empty' "$auth_file" 2>/dev/null)
      if [[ -n "$copilot_token" && "$copilot_token" != "null" ]]; then
        echo "copilot:${copilot_token:0:16}"
      fi
      ;;
  esac
}

# Get the first account ID from auth file for legacy callers.
get_account_id() {
  local auth_file="$1"
  local provider

  for provider in openai copilot; do
    local account_id=$(get_account_id_for_provider "$auth_file" "$provider")
    if [[ -n "$account_id" ]]; then
      echo "$account_id"
      return
    fi
  done
}

# Detect provider type from auth file
get_provider_from_auth() {
  local auth_file="$1"
  if [[ -f "$auth_file" ]]; then
    # Check which provider has valid auth
    if jq -e '.openai.accountId != null' "$auth_file" >/dev/null 2>&1; then
      echo "openai"
    elif jq -e '.["github-copilot"].access != null' "$auth_file" >/dev/null 2>&1; then
      echo "copilot"
    fi
  fi
}

get_plan_type_for_provider() {
  local auth_file="$1"
  local provider="$2"

  [[ ! -f "$auth_file" ]] && return

  if [[ "$provider" == "copilot" ]]; then
    echo "copilot"
    return
  fi

  local access_token=$(jq -r '.openai.access // .tokens.access_token // empty' "$auth_file" 2>/dev/null)
  if [[ -n "$access_token" && "$access_token" != "null" ]]; then
    local jwt_payload=$(echo "$access_token" | cut -d'.' -f2 | base64 -d 2>/dev/null)
    local plan=$(echo "$jwt_payload" | jq -r '.["https://api.openai.com/auth"].chatgpt_plan_type // empty' 2>/dev/null)
    if [[ "$plan" == "plus" || "$plan" == "pro" ]]; then
      echo "plus"
    else
      echo "free"
    fi
  fi
}

# Get plan type from auth file (OpenAI only)
get_plan_type_from_auth() {
  local auth_file="$1"
  local provider=$(get_provider_from_auth "$auth_file")
  get_plan_type_for_provider "$auth_file" "$provider"
}

# Check if an account ID already exists in any configured account
account_id_exists() {
  local target_id="$1"
  for acc in "${ACCOUNTS[@]}"; do
    local auth_file="$(get_account_auth_file "$acc")"
    local acc_id=$(get_account_id "$auth_file")
    if [[ "$acc_id" == "$target_id" ]]; then
      echo "$acc"
      return 0
    fi
  done
  return 1
}

find_reusable_account_slot() {
  local type="$1"
  local acc

  for acc in "${ACCOUNTS[@]}"; do
    [[ "${ACCOUNT_TYPES[$acc]}" != "$type" ]] && continue
    [[ -s "$(get_account_auth_file "$acc")" ]] && continue
    echo "$acc"
    return 0
  done

  return 1
}

update_account_config_entry() {
  local name="$1"
  local type="$2"
  local shortcut="$3"
  local display_name="$4"
  local tmp_file="${ACCOUNTS_CONF}.tmp"
  local line

  : > "$tmp_file"
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "${name}:${type}:${shortcut}" || "$line" == "${name}:${type}:${shortcut}:"* ]]; then
      print -r -- "${name}:${type}:${shortcut}:${display_name}" >> "$tmp_file"
    else
      print -r -- "$line" >> "$tmp_file"
    fi
  done < "$ACCOUNTS_CONF"

  mv "$tmp_file" "$ACCOUNTS_CONF"
}

write_provider_auth() {
  local source_auth="$1"
  local provider="$2"
  local target_auth="$3"

  case "$provider" in
    openai)
      jq '{openai: .openai, tokens: .tokens} | with_entries(select(.value != null))' "$source_auth" > "$target_auth"
      ;;
    copilot)
      jq '{"github-copilot": .["github-copilot"]} | with_entries(select(.value != null))' "$source_auth" > "$target_auth"
      ;;
  esac
}

import_provider_account() {
  local auth_file="$1"
  local source_home="$2"
  local provider="$3"
  local notice="$4"

  local account_id=$(get_account_id_for_provider "$auth_file" "$provider")
  [[ -z "$account_id" ]] && return 1

  local existing_acc=$(account_id_exists "$account_id")
  [[ -n "$existing_acc" ]] && return 1

  local plan_type=$(get_plan_type_for_provider "$auth_file" "$provider")
  [[ -z "$plan_type" ]] && plan_type="free"

  echo ""
  echo -e "${CYAN}${notice}${NC}"

  local display_name=""
  if [[ "$provider" == "openai" ]]; then
    display_name=$(get_opencode_account_email "$source_home")
  elif [[ "$provider" == "copilot" ]]; then
    display_name=$(get_copilot_login "$auth_file")
  fi

  local shortcut name
  local reused_slot=$(find_reusable_account_slot "$plan_type")
  if [[ -n "$reused_slot" ]]; then
    name="$reused_slot"
    shortcut="${ACCOUNT_SHORTCUTS[$name]}"
  else
    local next_num=$(get_next_account_number "$plan_type")
    case "$plan_type" in
      plus)
        shortcut="p${next_num}"
        name="plus${next_num}"
        ;;
      copilot)
        shortcut="c${next_num}"
        name="copilot${next_num}"
        ;;
      *)
        shortcut="f${next_num}"
        name="free${next_num}"
        ;;
    esac
  fi

  local new_data_dir="$(get_account_data_dir "$name")"
  mkdir -p "$new_data_dir"
  write_provider_auth "$auth_file" "$provider" "$new_data_dir/auth.json"
  setup_shared_symlinks "$new_data_dir"

  if [[ -n "$reused_slot" ]]; then
    if [[ -n "$display_name" || -n "${ACCOUNT_NAMES[$name]}" ]]; then
      update_account_config_entry "$name" "$plan_type" "$shortcut" "$display_name"
    fi
  else
    echo "${name}:${plan_type}:${shortcut}:${display_name}" >> "$ACCOUNTS_CONF"
  fi

  echo -e "${GREEN}Auto-added:${NC} ${BOLD}${display_name:-$name}${NC} (${plan_type}) -> ${BOLD}${shortcut}${NC}"
  if [[ -n "$reused_slot" ]]; then
    echo -e "${DIM}Reused existing slot ${shortcut}.${NC}"
  fi
  echo -e "Add alias to ~/.zshrc:  ${BOLD}alias ${shortcut}='ai ${shortcut}'${NC}"

  ACCOUNTS=()
  load_accounts
  return 0
}

# Auto-add new account if /connect was used
auto_add_new_account() {
  local auth_file="$2"
  local source_home="$(dirname "$auth_file")"
  local provider

  for provider in openai copilot; do
    import_provider_account "$auth_file" "$source_home" "$provider" "Detected new account via /connect!" || true
  done
}

# Check and import existing account from default opencode on first run
check_and_import_default_account() {
  local default_auth="$DATA_HOME_ROOT/opencode/auth.json"

  [[ ! -f "$default_auth" ]] && return 0

  local provider
  for provider in openai copilot; do
    import_provider_account "$default_auth" "$DATA_HOME_ROOT/opencode" "$provider" "Found existing logged-in account in default opencode!" || true
  done
}

# Auto-add from default opencode location (called by opencode wrapper)
auto_add_from_default() {
  local default_auth="$DATA_HOME_ROOT/opencode/auth.json"

  [[ ! -f "$default_auth" ]] && return 0

  local provider
  for provider in openai copilot; do
    import_provider_account "$default_auth" "$DATA_HOME_ROOT/opencode" "$provider" "Detected new account via /connect!" || true
  done
}

# Get db size (usage indicator)
get_db_size() {
  local acc=$1
  local db_file="$(get_account_data_dir "$acc")/opencode.db"
  if [[ -f "$db_file" ]]; then
    local size=$(stat -f%z "$db_file" 2>/dev/null || echo 0)
    if (( size > 1048576 )); then
      echo "$((size / 1048576))MB"
    else
      echo "$((size / 1024))KB"
    fi
  else
    echo "-"
  fi
}

# Get color for account type
get_type_color() {
  case "$1" in
    plus) echo "$YELLOW" ;;
    api)  echo "$MAGENTA" ;;
    copilot) echo "$BLUE" ;;
    *)    echo "$CYAN" ;;
  esac
}

# Update config file with display name
update_display_name() {
  local acc=$1
  local display_name=$2
  local shortcut="${ACCOUNT_SHORTCUTS[$acc]}"
  local type="${ACCOUNT_TYPES[$acc]}"
  
  # Update line in config file
  local tmp=$(mktemp)
  while IFS=: read -r name t s d || [[ -n "$name" ]]; do
    if [[ "$name" == "$acc" ]]; then
      echo "${name}:${t}:${s}:${display_name}"
    else
      if [[ -n "$d" ]]; then
        echo "${name}:${t}:${s}:${d}"
      elif [[ -n "$name" && ! "$name" =~ ^#.*$ ]]; then
        echo "${name}:${t}:${s}"
      else
        echo "$name"
      fi
    fi
  done < "$ACCOUNTS_CONF" > "$tmp"
  mv "$tmp" "$ACCOUNTS_CONF"
  ACCOUNT_NAMES[$acc]="$display_name"
}

renew_usage() {
  local refreshed=0
  local failed=0
  local skipped=0
  local acc

  echo ""
  echo -e "${BOLD}Refreshing usage data...${NC}"

  for acc in "${ACCOUNTS[@]}"; do
    local type="${ACCOUNT_TYPES[$acc]}"
    local shortcut="${ACCOUNT_SHORTCUTS[$acc]}"
    local auth_file="$(get_account_auth_file "$acc")"

    case "$type" in
      free|plus)
        if [[ ! -f "$auth_file" ]]; then
          echo -e "  ${YELLOW}-${NC} ${shortcut} not logged in"
          skipped=$((skipped + 1))
          continue
        fi

        if ! has_codex_cli; then
          echo -e "  ${YELLOW}-${NC} ${shortcut} skipped (codex not installed)"
          skipped=$((skipped + 1))
          continue
        fi

        local app_server_home="$(get_account_data_dir "$acc")"
        local codex_home="$(get_account_codex_home "$acc")"
        prepare_codex_launcher_home "$acc"

        if refresh_rate_limits_cache "$acc" "$app_server_home" "$codex_home" "$type"; then
          sync_display_name "$acc" >/dev/null 2>&1 || true
          echo -e "  ${GREEN}✓${NC} ${shortcut} refreshed (${LAST_USAGE_SOURCE})"
          refreshed=$((refreshed + 1))
        else
          echo -e "  ${RED}✗${NC} ${shortcut} refresh failed"
          failed=$((failed + 1))
        fi
        ;;
      copilot)
        if [[ ! -f "$auth_file" ]]; then
          echo -e "  ${YELLOW}-${NC} ${shortcut} not logged in"
          skipped=$((skipped + 1))
          continue
        fi

        if ! has_curl_cli; then
          echo -e "  ${YELLOW}-${NC} ${shortcut} skipped (curl not installed)"
          skipped=$((skipped + 1))
          continue
        fi

        if ! sync_display_name "$acc" >/dev/null 2>&1; then
          echo -e "  ${RED}✗${NC} ${shortcut} refresh failed"
          failed=$((failed + 1))
          continue
        fi

        echo -e "  ${GREEN}✓${NC} ${shortcut} refreshed (GitHub Copilot private usage API)"
        refreshed=$((refreshed + 1))
        ;;
      *)
        echo -e "  ${YELLOW}-${NC} ${shortcut} skipped (usage not supported)"
        skipped=$((skipped + 1))
        ;;
    esac
  done

  echo ""
  echo -e "${BOLD}Summary:${NC} ${GREEN}${refreshed} refreshed${NC}, ${RED}${failed} failed${NC}, ${YELLOW}${skipped} skipped${NC}"
  show_status
}

renew_command() {
  case "$1" in
    usage)
      renew_usage
      ;;
    *)
      echo -e "${RED}Usage: ai renew usage${NC}"
      return 1
      ;;
  esac
}

setup_shared_codex_home() {
  local codex_home="$1"
  local default_codex_home="$HOME/.codex"
  local entry

  mkdir -p "$codex_home"
  [[ ! -d "$default_codex_home" ]] && return 0

  for entry in "$default_codex_home"/*(DN); do
    local name="${entry:t}"
    local link="$codex_home/$name"

    case "$name" in
      auth.json|auth.json.bak)
        continue
        ;;
    esac

    if [[ -e "$link" && ! -L "$link" ]]; then
      rm -rf "$link"
    fi

    if [[ ! -L "$link" ]]; then
      ln -sfn "$entry" "$link"
    fi
  done
}

write_codex_launcher_auth() {
  local source_auth="$1"
  local target_auth="$2"
  local default_codex_auth="$HOME/.codex/auth.json"
  local account_id=$(jq -r '.openai.accountId // .tokens.account_id // .tokens.accountId // empty' "$source_auth" 2>/dev/null)

  if [[ -n "$account_id" && -f "$default_codex_auth" ]]; then
    local default_account_id=$(jq -r '.tokens.account_id // empty' "$default_codex_auth" 2>/dev/null)
    if [[ "$default_account_id" == "$account_id" ]]; then
      jq '{auth_mode: (.auth_mode // "chatgpt"), OPENAI_API_KEY: (.OPENAI_API_KEY // null), tokens: {id_token: (.tokens.id_token // null), access_token: (.tokens.access_token // null), refresh_token: (.tokens.refresh_token // null), account_id: (.tokens.account_id // null)}, last_refresh: (.last_refresh // null)}' "$default_codex_auth" > "$target_auth"
      return 0
    fi
  fi

  jq '{auth_mode: "chatgpt", OPENAI_API_KEY: null, tokens: {id_token: (.tokens.id_token // null), access_token: (.openai.access // .tokens.access_token // null), refresh_token: (.openai.refresh // .tokens.refresh_token // null), account_id: (.openai.accountId // .tokens.account_id // .tokens.accountId // null)}, last_refresh: null}' "$source_auth" > "$target_auth"
}

prepare_codex_launcher_home() {
  local acc="$1"
  local source_auth="$(get_account_auth_file "$acc")"
  local target_home="$(get_account_codex_home "$acc")"
  local target_auth="$target_home/auth.json"

  setup_shared_codex_home "$target_home"

  [[ ! -f "$source_auth" ]] && return 0
  jq -e '.openai? != null or .tokens? != null' "$source_auth" >/dev/null 2>&1 || return 0

  write_codex_launcher_auth "$source_auth" "$target_auth"
}

# Setup directories for all accounts
# Setup symlinks for shared resources in per-account data directory
# This allows auth isolation while sharing sessions, plugins, etc.
setup_shared_symlinks() {
  local data_dir="$1"
  local default_data="$DATA_HOME_ROOT/opencode"
  
  # Files to symlink (session database and its WAL files)
  local shared_files=(
    "opencode.db"
    "opencode.db-shm"
    "opencode.db-wal"
  )
  
  # Directories to symlink
  local shared_dirs=(
    "log"
    "tool-output"
    "storage"
    "plugins"
    "snapshot"
    "backup"
    "bin"
    "worktree"
  )
  
  # Create symlinks for shared files
  for f in "${shared_files[@]}"; do
    local target="$default_data/$f"
    local link="$data_dir/$f"
    
    # Remove existing file/link if it's not already correct
    if [[ -e "$link" && ! -L "$link" ]]; then
      rm -f "$link"
    fi
    
    # Create symlink if target exists and link doesn't
    if [[ -e "$target" && ! -L "$link" ]]; then
      ln -sf "$target" "$link"
    fi
  done
  
  # Create symlinks for shared directories
  for d in "${shared_dirs[@]}"; do
    local target="$default_data/$d"
    local link="$data_dir/$d"
    
    # Remove existing dir/link if it's not already a symlink
    if [[ -d "$link" && ! -L "$link" ]]; then
      rm -rf "$link"
    fi
    
    # Create symlink if target exists and link doesn't
    if [[ -d "$target" && ! -L "$link" ]]; then
      ln -sf "$target" "$link"
    fi
  done
}

setup_accounts() {
  echo -e "${BOLD}Setting up account directories...${NC}"
  
  # Ensure default opencode data directory exists
  local default_data="$DATA_HOME_ROOT/opencode"
  if [[ ! -d "$default_data" ]]; then
    echo -e "${YELLOW}Warning: Default opencode data not found at $default_data${NC}"
    echo "Run opencode once first to initialize it."
  fi
  
  for acc in "${ACCOUNTS[@]}"; do
    local data_home="$(get_account_data_home "$acc")"
    local data_dir="$(get_account_data_dir "$acc")"
    local codex_home="$(get_account_codex_home "$acc")"
    
    # Create per-account data directory for auth isolation
    if [[ ! -d "$data_dir" ]]; then
      mkdir -p "$data_dir"
      echo -e "  ${GREEN}+${NC} Created data dir: $acc"
    fi
    
    # Setup symlinks to shared resources
    setup_shared_symlinks "$data_dir"
    echo -e "  ${GREEN}↔${NC} Symlinks updated: $acc"

    if [[ ! -d "$codex_home" ]]; then
      mkdir -p "$codex_home"
      echo -e "  ${GREEN}+${NC} Created codex home: $acc"
    fi

    prepare_codex_launcher_home "$acc"
    echo -e "  ${GREEN}↔${NC} Codex home updated: $acc"
  done
  
  echo -e "\n${GREEN}Done!${NC} Run 'ai' to see status."
  echo -e "${DIM}Accounts share sessions/plugins via symlinks, auth is isolated.${NC}"
}

# Show status of all accounts
show_status() {
  echo ""
  echo -e "${BOLD}AI Multi-Account Status${NC}"
  echo "========================"

  local type
  for type in free plus copilot api; do
    local printed_header=""

    for acc in "${ACCOUNTS[@]}"; do
      [[ "${ACCOUNT_TYPES[$acc]}" != "$type" ]] && continue

      local shortcut="${ACCOUNT_SHORTCUTS[$acc]}"
      local display_name="${ACCOUNT_NAMES[$acc]}"
      local limit_summary=""
      # Only show rate limits for OpenAI accounts (free/plus)
      if [[ "$type" == "free" || "$type" == "plus" ]]; then
        limit_summary=$(get_cached_limit_summary "$acc")
      elif [[ "$type" == "copilot" ]]; then
        limit_summary=$(get_copilot_limit_summary "$acc")
      fi
      local type_color=$(get_type_color "$type")

      if [[ -z "$printed_header" ]]; then
        echo ""
        local type_upper=$(echo "$type" | tr '[:lower:]' '[:upper:]')
        echo -e "${type_color}${type_upper} Accounts:${NC}"
        printed_header=1
      fi

      if [[ -n "$display_name" ]]; then
        if is_logged_in "$acc"; then
          echo -e "  ${GREEN}●${NC} ${BOLD}${shortcut}${NC}  ${display_name}${limit_summary:+  ${DIM}${limit_summary}${NC}}"
        else
          echo -e "  ${RED}○${NC} ${shortcut}  ${display_name}${limit_summary:+  ${DIM}${limit_summary}${NC}}"
        fi
      else
        if is_logged_in "$acc"; then
          echo -e "  ${GREEN}●${NC} ${BOLD}${shortcut}${NC}  ${DIM}(no name)${NC}${limit_summary:+  ${DIM}${limit_summary}${NC}}"
        else
          echo -e "  ${RED}○${NC} ${shortcut}  ${DIM}(not logged in)${NC}${limit_summary:+  ${DIM}${limit_summary}${NC}}"
        fi
      fi
    done
  done
  
  echo ""
  echo -e "${BOLD}Commands:${NC}"
  echo "  ai                  Show this status"
  echo "  ai <shortcut>       Launch account (e.g., ai f1)"
  echo "  ai codex <shortcut> Launch Codex with account"
  echo "  ai usage <shortcut> Show plan & usage info"
  echo "  ai renew usage      Refresh usage data for all supported accounts"
  echo "  ai add [TYPE]       Add account (free/plus/copilot/api)"
  echo "  ai rm <shortcut>    Remove account"
  echo ""
}

# Add new account
get_next_account_number() {
  local type="$1"
  local prefix

  case "$type" in
    plus) prefix="p" ;;
    api) prefix="a" ;;
    copilot) prefix="c" ;;
    *) prefix="f" ;;
  esac

  local max_num=0
  local acc
  for acc in "${ACCOUNTS[@]}"; do
    [[ "${ACCOUNT_TYPES[$acc]}" != "$type" ]] && continue

    local name_suffix="${acc#$type}"
    if [[ "$name_suffix" != "$acc" && -n "$name_suffix" && "$name_suffix" = <-> && "$name_suffix" -gt "$max_num" ]]; then
      max_num=$name_suffix
    fi

    local shortcut="${ACCOUNT_SHORTCUTS[$acc]}"
    local shortcut_suffix="${shortcut#$prefix}"
    if [[ "$shortcut_suffix" != "$shortcut" && -n "$shortcut_suffix" && "$shortcut_suffix" = <-> && "$shortcut_suffix" -gt "$max_num" ]]; then
      max_num=$shortcut_suffix
    fi
  done

  echo $((max_num + 1))
}

add_account() {
  local type=${1:-free}
  
  # Generate name and shortcut
  local shortcut
  local name
  if [[ "$type" == "plus" ]]; then
    local next_num=$(get_next_account_number "plus")
    shortcut="p${next_num}"
    name="plus${next_num}"
  elif [[ "$type" == "api" ]]; then
    local next_num=$(get_next_account_number "api")
    shortcut="a${next_num}"
    name="api${next_num}"
  elif [[ "$type" == "copilot" ]]; then
    local next_num=$(get_next_account_number "copilot")
    shortcut="c${next_num}"
    name="copilot${next_num}"
  else
    type="free"
    local next_num=$(get_next_account_number "free")
    shortcut="f${next_num}"
    name="free${next_num}"
  fi
  
  # Add to config
  echo "${name}:${type}:${shortcut}:" >> "$ACCOUNTS_CONF"
  echo -e "${GREEN}Added:${NC} ${name} (${type}) -> ${BOLD}${shortcut}${NC}"
  
  # Setup data directory with symlinks
  local data_dir="$(get_account_data_dir "$name")"
  mkdir -p "$data_dir"
  setup_shared_symlinks "$data_dir"

  local codex_home="$(get_account_codex_home "$name")"
  mkdir -p "$codex_home"
  prepare_codex_launcher_home "$name"
  
  echo -e "${GREEN}Created data directory with shared symlinks${NC}"
  echo ""
  echo -e "Add to ~/.zshrc:  ${BOLD}alias ${shortcut}='ai ${shortcut}'${NC}"
  echo -e "Then run:         ${BOLD}${shortcut}${NC}"
  echo ""
  echo -e "${DIM}After login, name will auto-update to your email${NC}"
}

# Remove account
remove_account() {
  local input=$1
  
  if [[ -z "$input" ]]; then
    echo -e "${RED}Usage: ai rm <shortcut>${NC}"
    echo "Example: ai rm f3"
    return 1
  fi
  
  # Resolve shortcut to account name
  local acc
  if [[ -n "${SHORTCUT_TO_ACCOUNT[$input]}" ]]; then
    acc="${SHORTCUT_TO_ACCOUNT[$input]}"
  elif [[ " ${ACCOUNTS[@]} " =~ " ${input} " ]]; then
    acc="$input"
  else
    echo -e "${RED}Unknown account: $input${NC}"
    return 1
  fi
  
  local shortcut="${ACCOUNT_SHORTCUTS[$acc]}"
  local display_name=$(sync_display_name "$acc" 2>/dev/null || get_display_name "$acc")
  
  echo -e "${YELLOW}Remove account:${NC} ${acc} (${shortcut}) - ${display_name}"
  echo -n "Delete data too? [y/N]: "
  read -r delete_data
  
  # Remove from config
  local tmp=$(mktemp)
  grep -v "^${acc}:" "$ACCOUNTS_CONF" > "$tmp"
  mv "$tmp" "$ACCOUNTS_CONF"
  echo -e "${GREEN}Removed from config${NC}"
  
  # Optionally delete data
  if [[ "$delete_data" =~ ^[Yy]$ ]]; then
    rm -rf "$(get_account_config_home "$acc")"
    rm -rf "$(get_account_data_home "$acc")"
    rm -rf "$(get_account_state_home "$acc")"
    rm -rf "$(get_account_codex_home "$acc")"
    echo -e "${GREEN}Deleted directories${NC}"
  else
    echo -e "${DIM}Data kept in:${NC}"
    echo "  $(get_account_config_home "$acc")"
    echo "  $(get_account_data_home "$acc")"
    echo "  $(get_account_state_home "$acc")"
    echo "  $(get_account_codex_home "$acc")"
  fi
  
  echo ""
  echo -e "Remove alias from ~/.zshrc:  ${BOLD}alias ${shortcut}=...${NC}"
}

# Rename account (set display name)
rename_account() {
  local input=$1
  local new_name=$2
  
  if [[ -z "$input" || -z "$new_name" ]]; then
    echo -e "${RED}Usage: ai rename <shortcut> <new_name>${NC}"
    echo "Example: ai rename f1 work-account"
    return 1
  fi
  
  # Resolve shortcut to account name
  local acc
  if [[ -n "${SHORTCUT_TO_ACCOUNT[$input]}" ]]; then
    acc="${SHORTCUT_TO_ACCOUNT[$input]}"
  else
    echo -e "${RED}Unknown account: $input${NC}"
    return 1
  fi
  
  update_display_name "$acc" "$new_name"
  echo -e "${GREEN}Renamed:${NC} ${input} -> ${new_name}"
}

# Show usage for an account using codex app-server
show_usage() {
  local input=$1
  
  if [[ -z "$input" ]]; then
    echo -e "${RED}Usage: ai usage <shortcut>${NC}"
    echo "Example: ai usage f1"
    return 1
  fi
  
  # Resolve shortcut to account name
  local acc
  if [[ -n "${SHORTCUT_TO_ACCOUNT[$input]}" ]]; then
    acc="${SHORTCUT_TO_ACCOUNT[$input]}"
  elif [[ " ${ACCOUNTS[@]} " =~ " ${input} " ]]; then
    acc="$input"
  else
    echo -e "${RED}Unknown account: $input${NC}"
    return 1
  fi
  
  local type="${ACCOUNT_TYPES[$acc]}"
  local type_color=$(get_type_color "$type")
  local display_name=$(get_display_name "$acc")
  
  local data_home="$(get_account_data_home "$acc")"
  local app_server_home="$(get_account_data_dir "$acc")"
  local codex_launcher_home="$(get_account_codex_home "$acc")"
  local auth_file="$(get_account_auth_file "$acc")"
  
  if [[ ! -d "$data_home" ]]; then
    echo -e "${RED}Account not set up: $acc${NC}"
    echo "Run 'ai setup' first"
    return 1
  fi
  
  # Check if logged in
  if [[ ! -f "$auth_file" ]]; then
    echo -e "${RED}Not logged in: $acc${NC}"
    echo "Launch account first: ai $input"
    return 1
  fi
  
  echo ""
  echo -e "${BOLD}Account: ${display_name:-$acc}${NC} ${type_color}(${type})${NC}"
  echo "================================"
  
  # Try to get email from account auth
  local email=$(get_email "$acc")
  if [[ -n "$email" ]]; then
    local current_display="${ACCOUNT_NAMES[$acc]}"
    if [[ -z "$current_display" || "$current_display" == "${email%%@*}" ]]; then
      update_display_name "$acc" "$email"
    fi
    echo -e "Email: ${email}"
  fi
  
  # Get rate limits from codex app-server (only for OpenAI accounts)
  if [[ "$type" == "free" || "$type" == "plus" ]]; then
    if ! has_codex_cli; then
      echo -e "${YELLOW}codex CLI not found${NC}"
      echo "install codex to read usage limits"
    else
      prepare_codex_launcher_home "$acc"
      if display_rate_limits "$app_server_home" "$acc" "$codex_launcher_home" "$type"; then
        echo ""
        echo -e "${DIM}Data from ${LAST_USAGE_SOURCE}${NC}"
      else
        echo -e "${YELLOW}Could not fetch rate limits${NC}"
        echo "Account may not be logged in"
      fi
    fi
  elif [[ "$type" == "copilot" ]]; then
    if ! has_curl_cli; then
      echo -e "${YELLOW}curl not found${NC}"
      echo "install curl to read GitHub Copilot usage"
    elif display_copilot_usage "$auth_file"; then
      echo ""
      echo -e "${DIM}Data from ${LAST_USAGE_SOURCE}${NC}"
    else
      echo -e "${YELLOW}Could not fetch GitHub Copilot usage${NC}"
      echo "GitHub account may need to be reconnected"
    fi
  fi
  
  echo ""
}

# Launch opencode with specific account
launch() {
  local input=$1
  shift
  
  # Resolve shortcut to account name
  local acc
  if [[ -n "${SHORTCUT_TO_ACCOUNT[$input]}" ]]; then
    acc="${SHORTCUT_TO_ACCOUNT[$input]}"
  elif [[ " ${ACCOUNTS[@]} " =~ " ${input} " ]]; then
    acc="$input"
  else
    echo -e "${RED}Unknown account: $input${NC}"
    echo "Run 'ai' to see available accounts"
    return 1
  fi
  
  local data_home="$(get_account_data_home "$acc")"
  local data_dir="$(get_account_data_dir "$acc")"
  local codex_home="$(get_account_codex_home "$acc")"
  local type="${ACCOUNT_TYPES[$acc]}"
  local type_color=$(get_type_color "$type")
  local display_name=$(sync_display_name "$acc" 2>/dev/null || get_display_name "$acc")
  
  # Check if data directory exists
  if [[ ! -d "$data_dir" ]]; then
    echo -e "${RED}Data dir not found. Run: ai setup${NC}"
    return 1
  fi
  
  # Ensure symlinks are up to date before launch
  setup_shared_symlinks "$data_dir"
  
  # Record usage timestamp
  init_usage
  record_account_usage_timestamp "$acc"
  
  # Show launch message
  if [[ -n "$display_name" ]]; then
    echo -e "${GREEN}Launching${NC} ${BOLD}${display_name}${NC} ${type_color}(${type})${NC}"
  else
    echo -e "${GREEN}Launching${NC} ${BOLD}${acc}${NC} ${type_color}(${type})${NC}"
  fi
  
  # Record current account ID before launch (for detecting /connect)
  local auth_file="$data_dir/auth.json"
  local old_account_id=$(get_account_id "$auth_file")
  
  # Launch opencode with only XDG_DATA_HOME overridden for auth isolation
  # Config and state use defaults, so plugins/sessions are shared
  XDG_DATA_HOME="$data_home" \
  opencode "$@"

  # Refresh rate limits cache (only for OpenAI accounts)
  if [[ "$type" == "free" || "$type" == "plus" ]]; then
    prepare_codex_launcher_home "$acc"
    refresh_rate_limits_cache "$acc" "$data_dir" "$codex_home" "$type" >/dev/null 2>&1 || true
  fi
  
  # Check if user used /connect to add a new account
  auto_add_new_account "$acc" "$auth_file" "$old_account_id"
  
  # After exit, check if we should update display name
  local updated_display_name=$(sync_display_name "$acc" 2>/dev/null || true)
  if [[ -n "$updated_display_name" && "$updated_display_name" != "$display_name" ]]; then
    echo -e "${DIM}Updated name: ${updated_display_name}${NC}"
  fi
}

launch_codex() {
  local input=$1
  shift

  local acc
  if [[ -n "${SHORTCUT_TO_ACCOUNT[$input]}" ]]; then
    acc="${SHORTCUT_TO_ACCOUNT[$input]}"
  elif [[ " ${ACCOUNTS[@]} " =~ " ${input} " ]]; then
    acc="$input"
  else
    echo -e "${RED}Unknown account: $input${NC}"
    echo "Run 'ai' to see available accounts"
    return 1
  fi

  local codex_cmd=$(get_codex_command)
  if [[ -z "$codex_cmd" ]]; then
    echo -e "${RED}codex CLI not found${NC}"
    echo "Install codex first"
    return 1
  fi

  local type="${ACCOUNT_TYPES[$acc]}"
  local type_color=$(get_type_color "$type")
  local display_name=$(sync_display_name "$acc" 2>/dev/null || get_display_name "$acc")
  local codex_home="$(get_account_codex_home "$acc")"
  local app_server_home="$(get_account_data_dir "$acc")"
  local auth_file="$(get_account_auth_file "$acc")"

  if [[ "$type" != "free" && "$type" != "plus" ]]; then
    echo -e "${RED}Codex launcher currently supports OpenAI free/plus accounts only${NC}"
    return 1
  fi

  if [[ ! -f "$auth_file" ]]; then
    echo -e "${RED}Not logged in: $acc${NC}"
    echo "Launch account first: ai $input"
    return 1
  fi

  prepare_codex_launcher_home "$acc"

  init_usage
  record_account_usage_timestamp "$acc"

  # Record current account ID before launch (for detecting login change)
  local old_account_id=$(jq -r '.tokens.account_id // empty' "$codex_home/auth.json" 2>/dev/null)

  if [[ -n "$display_name" ]]; then
    echo -e "${GREEN}Launching${NC} ${BOLD}${display_name}${NC} ${type_color}(${type})${NC} in ${BOLD}codex${NC}"
  else
    echo -e "${GREEN}Launching${NC} ${BOLD}${acc}${NC} ${type_color}(${type})${NC} in ${BOLD}codex${NC}"
  fi

  CODEX_HOME="$codex_home" \
  "$codex_cmd" "$@"

  refresh_rate_limits_cache "$acc" "$app_server_home" "$codex_home" "$type" >/dev/null 2>&1 || true

  # Check if user logged in with a new account in codex
  local new_codex_auth="$codex_home/auth.json"
  if [[ -f "$new_codex_auth" ]]; then
    local new_account_id=$(jq -r '.tokens.account_id // empty' "$new_codex_auth" 2>/dev/null)
    if [[ -n "$new_account_id" && "$new_account_id" != "$old_account_id" ]]; then
      # Convert codex auth format to opencode format and import
      local tmp_opencode_auth=$(mktemp)
      jq '{openai: {access: .tokens.access_token, refresh: .tokens.refresh_token, accountId: .tokens.account_id, type: "chatgpt", expires: null}}' "$new_codex_auth" > "$tmp_opencode_auth"
      import_provider_account "$tmp_opencode_auth" "$codex_home" "openai" "Detected new account via codex login!" || true
      rm -f "$tmp_opencode_auth"
    fi
  fi
}

# Main
load_accounts
init_usage

# On first run or when no accounts, check for existing logged-in account
check_and_import_default_account

case "$1" in
  ""|status|list|ls)
    show_status
    ;;
  codex)
    launch_codex "$2" "${@:3}"
    ;;
  opencode)
    launch "$2" "${@:3}"
    ;;
  setup)
    setup_accounts
    ;;
  add)
    add_account "$2"
    ;;
  rm|remove|del|delete)
    remove_account "$2"
    ;;
  rename|name)
    rename_account "$2" "$3"
    ;;
  usage|u)
    show_usage "$2"
    ;;
  renew)
    renew_command "$2"
    ;;
  help|-h|--help)
    echo "AI Multi-Account Manager"
    echo ""
    echo "Usage: ai [command]"
    echo ""
    echo "Commands:"
    echo "  ai                  Show status of all accounts"
    echo "  ai <shortcut>       Launch account (e.g., f1, p1, c1)"
    echo "  ai codex <shortcut> Launch Codex with account"
    echo "  ai usage <shortcut> Show account usage/plan info"
    echo "  ai renew usage      Refresh usage data for all supported accounts"
    echo "  ai add [TYPE]       Add account (free/plus/copilot/api)"
    echo "  ai rm <shortcut>    Remove account"
    echo "  ai rename <s> <n>   Set display name"
    echo "  ai setup            Create directories"
    echo ""
    echo "Config: $ACCOUNTS_CONF"
    ;;
  __auto_add_default)
    # Internal: called by opencode wrapper to auto-add from default location
    auto_add_from_default "$2"
    ;;
  *)
    launch "$@"
    ;;
esac
